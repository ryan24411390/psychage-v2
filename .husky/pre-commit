# Check if lockfile is in sync with package.json
if git diff --cached --name-only | grep -q "package.json"; then
  echo "📦 package.json modified, checking lockfile sync..."

  # If package.json is staged but lockfile isn't, remind user
  if ! git diff --cached --name-only | grep -qE "pnpm-lock.yaml|package-lock.json"; then
    echo "⚠️  package.json changed but lockfile not staged"
    echo "   Run 'pnpm install' and stage the updated lockfile"
    exit 1
  fi

  echo "✅ Lockfile is in sync"
fi
