# Copy to .env.e2e (gitignored) to run the Playwright suite against production.
# This is the SINGLE production Supabase project (there is no separate staging).

# Supabase — same project the app uses:
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon public key>
# Service role is used ONLY by global-setup (confirm test account) and cleanup —
# never shipped to the browser. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Dedicated, disposable test account (created on first run; every row it writes
# is on the cleanup list — see scripts/e2e-cleanup.mjs):
PSYCHAGE_E2E_EMAIL=e2e-verify+<date>@psychage.com
PSYCHAGE_E2E_PASSWORD=<strong password>

# Target. Omit for local dev (defaults to http://localhost:5173):
# PLAYWRIGHT_BASE_URL=https://www.psychage.com
