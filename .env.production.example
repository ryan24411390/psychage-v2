# ============================================================================
# PSYCHAGE V2 - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Complete environment configuration for production deployment
# Copy this file to .env for local development
# Add all values to Vercel Environment Variables for production
# ============================================================================

# ============================================================================
# 🔴 CRITICAL - REQUIRED FOR ALL DEPLOYMENTS
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE DATABASE (Required)
# ----------------------------------------------------------------------------
# Get from: https://supabase.com/dashboard → Project Settings → API
# Used by: Frontend (client-side), Backend API routes (server-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only (NEVER expose to client)
# Get from: Supabase → Settings → API → service_role key (secret)
# Used by: API routes for admin operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# SANITY CMS (Required for content)
# ----------------------------------------------------------------------------
# Get from: https://sanity.io/manage → Project Settings
# Used by: Content services, article/video fetching
VITE_SANITY_PROJECT_ID=your-sanity-project-id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Webhook secret for content ingestion
# Generate with: openssl rand -base64 32
# Used by: /api/ai/embed webhook endpoint
SANITY_WEBHOOK_SECRET=your-random-webhook-secret-here

# ----------------------------------------------------------------------------
# ANTHROPIC API (Required for MindMate AI + Crisis Companion)
# ----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
# Model: Claude Sonnet 4.5 (claude-sonnet-4-5-20250929)
# Cost: ~$3 per 1M input tokens, ~$15 per 1M output tokens
# Used by: /api/ai/chat, /api/crisis-companion
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----------------------------------------------------------------------------
# OPENAI API (Required for content embeddings)
# ----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
# Model: text-embedding-3-small
# Cost: ~$0.02 per 1M tokens
# Used by: /api/ai/embed, content ingestion scripts
OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------------------
# LLM PROVIDER SELECTION (Optional, server-side)
# ----------------------------------------------------------------------------
# Switch primary LLM: 'anthropic' (default) or 'openai'
# Used by: src/lib/ai/config.ts
LLM_PROVIDER=anthropic

# ============================================================================
# 🟡 RECOMMENDED - IMPROVES FUNCTIONALITY
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND API (If using separate backend)
# ----------------------------------------------------------------------------
# Only needed if Psychage V1 backend is deployed separately
# Leave blank if using serverless API routes only
VITE_API_URL=https://api.psychage.com

# ============================================================================
# 🟢 OPTIONAL - PHASE 2+ FEATURES
# ============================================================================

# ----------------------------------------------------------------------------
# THROUGHLINE API (Crisis helpline database)
# ----------------------------------------------------------------------------
# Get from: https://throughlinecare.com
# Used by: /api/throughline (crisis resource lookup)
# Falls back to static resources if not configured
THROUGHLINE_API_KEY=your-throughline-key
THROUGHLINE_API_BASE_URL=https://api.throughlinecare.com/v1

# ----------------------------------------------------------------------------
# BRAVE SEARCH API (Web search fallback)
# ----------------------------------------------------------------------------
# Get from: https://brave.com/search/api/
# Used by: Future web search features (Phase 2)
BRAVE_SEARCH_API_KEY=your-brave-api-key

# ----------------------------------------------------------------------------
# VERCEL KV (Redis-compatible caching)
# ----------------------------------------------------------------------------
# Auto-populated when you add Vercel KV storage
# Used by: Rate limiting, response caching (Phase 2)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ----------------------------------------------------------------------------
# SENTRY (Error tracking & monitoring)
# ----------------------------------------------------------------------------
# Get from: https://sentry.io
# Used by: Error logging, performance monitoring
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================================
# 🎛️ CONFIGURATION - OPTIONAL TUNING
# ============================================================================

# ----------------------------------------------------------------------------
# Application Metadata
# ----------------------------------------------------------------------------
VITE_APP_NAME=Psychage
VITE_APP_VERSION=2.0.0

# ----------------------------------------------------------------------------
# MindMate AI Configuration
# ----------------------------------------------------------------------------
# RAG similarity threshold (0-1, default: 0.72)
MINDMATE_RAG_THRESHOLD=0.72

# Citation threshold (0-1, default: 0.75)
MINDMATE_CITATION_THRESHOLD=0.75

# Max results from RAG search (default: 5)
MINDMATE_MAX_RAG_RESULTS=5

# Rate limit (requests per minute per IP, default: 20)
MINDMATE_RATE_LIMIT_REQUESTS=20

# Cache TTL in seconds (default: 900 = 15 minutes)
MINDMATE_CACHE_TTL=900

# ----------------------------------------------------------------------------
# Crisis System Configuration
# ----------------------------------------------------------------------------
# Max AI companion calls per session (Tier 3 crisis exempt, default: 20)
VITE_CRISIS_AI_RATE_LIMIT=20

# Safety plan encryption salt (32-byte hex)
# Generate with: openssl rand -hex 32
# Leave blank to use default salt (less secure)
VITE_SAFETY_PLAN_ENCRYPTION_SALT=

# Use ThroughLine API or fallback only (default: false)
VITE_THROUGHLINE_FALLBACK_ONLY=false

# ----------------------------------------------------------------------------
# Feature Flags (Enable/Disable Features)
# ----------------------------------------------------------------------------
# Core features (default: true)
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_PROVIDER_DIRECTORY=true
VITE_ENABLE_MOOD_JOURNAL=true
VITE_ENABLE_SLEEP_TRACKER=true
VITE_ENABLE_CLARITY_SCORE=true

# Crisis system features (default: true)
VITE_CRISIS_DETECTION_ENABLED=true
VITE_MOOD_TRACKING_ENABLED=true
VITE_SAFETY_PLAN_ENABLED=true

# Symptom Navigator condition tiers (phased rollout)
# Tier 1: SCZ, BPD, BN, PGD (baseline conditions)
VITE_NAV_TIER1_ENABLED=true

# Tier 2: ASD, BDD, DPDR, SPP, PMDD
VITE_NAV_TIER2_ENABLED=false

# Tier 3: SADD, HD, SSD, IAD, AVPD, SEPA
VITE_NAV_TIER3_ENABLED=false

# Phase 4 expansion tiers
# Tier 4: NPD, ASPD, CPTSD, DID (high clinical severity)
VITE_NAV_TIER4_ENABLED=false

# Tier 5: DPD, SZPD, OSDD, ASD_ACUTE, TTM, SPD_EXCOR
VITE_NAV_TIER5_ENABLED=false

# Tier 6: IED, HYPER, ARFID, CYC (extensions)
VITE_NAV_TIER6_ENABLED=false

# ----------------------------------------------------------------------------
# Development Settings
# ----------------------------------------------------------------------------
# Enable verbose logging (default: false for production)
VITE_DEBUG_MODE=false
MINDMATE_DEBUG=false

# ============================================================================
# 📋 DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# 1. ✅ Add all CRITICAL variables to Vercel dashboard
# 2. ✅ Verify API keys are valid and funded
# 3. ✅ Run database migrations in production Supabase
# 4. ✅ Configure Sanity webhook to point to production URL
# 5. ✅ Set VITE_DEBUG_MODE=false
# 6. ✅ Add production domain to:
#    - Supabase Authentication settings (Site URL, Redirect URLs)
#    - Google Cloud Console (Gemini API restrictions)
# 7. ✅ Test all features in staging environment first
# 8. ✅ Set up error monitoring (Sentry recommended)
# 9. ✅ Configure CORS if using separate backend
# 10. ✅ Review rate limits based on expected traffic
#
# ============================================================================
# 💰 ESTIMATED COSTS (Monthly, 1000 users)
# ============================================================================
# Anthropic (MindMate AI):         $10-15
# OpenAI (Embeddings):              $0.50-1
# Supabase (Free tier):             $0 (up to 500MB DB, 2GB bandwidth)
# Vercel (Hobby):                   $0 (up to 100GB bandwidth)
# ────────────────────────────────────
# Total:                            $10-20/month
#
# Scale costs (10,000 users):
# Anthropic:                        $100-150
# Supabase (Pro):                   $25
# Vercel (Pro):                     $20
# ────────────────────────────────────
# Total:                            $145-195/month
# ============================================================================

# ============================================================================
# 🔐 SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env to git (already in .gitignore)
# 2. NEVER expose SUPABASE_SERVICE_ROLE_KEY to client
# 3. NEVER expose ANTHROPIC_API_KEY or OPENAI_API_KEY to client
# 4. Rotate API keys if compromised
# 5. Use Vercel Environment Variables for production (encrypted at rest)
# 6. Enable API key restrictions where possible (IP, referer, API scope)
# 7. Monitor API usage for anomalies
# 8. Set up billing alerts on all API providers
# ============================================================================

