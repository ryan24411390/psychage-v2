# ==================== CRISIS DETECTION SYSTEM ====================
# Environment variables for the Psychage Crisis Detection & Management System
#
# IMPORTANT: Never commit actual API keys to version control.
# Copy this file to .env and fill in your actual values.

# ==================== ANTHROPIC API ====================
# Claude API for crisis companion responses
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ==================== THROUGHLINE API ====================
# ThroughLine crisis helpline database API
# Get your key at: https://throughlinecare.com
THROUGHLINE_API_KEY=your_throughline_api_key_here
THROUGHLINE_API_BASE_URL=https://api.throughlinecare.com/v1

# ==================== SUPABASE ====================
# Already configured in main .env
# Crisis system uses these tables:
# - crisis_events (anonymous logging)
# - mood_logs (mood tracking)
# - safety_plans (encrypted storage)
# - crisis_resources_cache (ThroughLine cache)

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Server-side only, never exposed to client

# ==================== ENCRYPTION ====================
# 32-byte random hex string for safety plan encryption
# Generate with: openssl rand -hex 32
VITE_SAFETY_PLAN_ENCRYPTION_SALT=your_random_32_byte_hex_string_here

# ==================== MONITORING (OPTIONAL) ====================
# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ==================== FEATURE FLAGS ====================
# Enable/disable crisis detection system
VITE_CRISIS_DETECTION_ENABLED=true

# Use ThroughLine API or fallback only (useful during development without API key)
VITE_THROUGHLINE_FALLBACK_ONLY=false

# Enable mood tracking system
VITE_MOOD_TRACKING_ENABLED=true

# Enable safety plan builder
VITE_SAFETY_PLAN_ENABLED=true

# ==================== RATE LIMITING ====================
# Max AI companion calls per session (TIER 3 exempt)
VITE_CRISIS_AI_RATE_LIMIT=20

# ==================== NOTES ====================
# 1. The crisis detection engine runs 100% client-side — no API keys needed for detection
# 2. API keys are only used for:
#    - AI companion responses (Anthropic)
#    - Crisis resource lookup (ThroughLine)
# 3. If API keys are missing, system falls back to static resources and messages
# 4. NEVER store safety plan encryption keys in Supabase — keys are user-derived
