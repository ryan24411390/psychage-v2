  },

  "animation_triggers_legend": {
    "LOOP": "Continuous looping animation, always playing when visible",
    "HOVER": "Plays forward on mouseenter, reverses on mouseleave",
    "CLICK": "Plays once on click/tap, then resets",
    "SCROLL": "Plays once when element enters viewport (IntersectionObserver)",
    "STATE": "Two-segment animation — frame 0→N for 'on', frame N→0 for 'off'",
    "MORPH": "Shape morphs between two distinct icons",
    "FOCUS": "Plays when parent input receives focus",
    "STAGGER": "Plays in sequence with sibling icons (cascade effect)"
  },

