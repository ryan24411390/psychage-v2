# ============================================================================
# MINDMATE 2.0 AI CONFIGURATION
# ============================================================================
# Copy these values to your .env file
# ============================================================================

# ----------------------------------------------------------------------------
# ANTHROPIC (Claude Sonnet 4.5 for chat generation)
# ----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ----------------------------------------------------------------------------
# OPENAI (Embeddings only - text-embedding-3-small)
# ----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ----------------------------------------------------------------------------
# BRAVE SEARCH API (Phase 2 - Web search fallback)
# ----------------------------------------------------------------------------
# Get from: https://brave.com/search/api/
# Not needed for Phase 1 MVP
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# ----------------------------------------------------------------------------
# VERCEL KV (Phase 2 - Response caching)
# ----------------------------------------------------------------------------
# Auto-populated when you add KV storage in Vercel dashboard
# Not needed for Phase 1 MVP
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ----------------------------------------------------------------------------
# SANITY WEBHOOK SECRET (Content ingestion)
# ----------------------------------------------------------------------------
# Generate a random secret: openssl rand -base64 32
SANITY_WEBHOOK_SECRET=your-webhook-secret-here

# ----------------------------------------------------------------------------
# AI CONFIGURATION (Optional - uses defaults if not set)
# ----------------------------------------------------------------------------
# RAG similarity threshold (0-1, default: 0.72)
MINDMATE_RAG_THRESHOLD=0.72

# Citation threshold (0-1, default: 0.75)
MINDMATE_CITATION_THRESHOLD=0.75

# Max results from RAG (default: 5)
MINDMATE_MAX_RAG_RESULTS=5

# Rate limit per IP (requests per minute, default: 20)
MINDMATE_RATE_LIMIT_REQUESTS=20

# Cache TTL in seconds (default: 900 = 15 minutes)
MINDMATE_CACHE_TTL=900

# Enable debug logging (default: false)
MINDMATE_DEBUG=false
