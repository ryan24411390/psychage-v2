# ============================================================================
# PSYCHAGE FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your values
# For local development, update VITE_API_URL to point to your local backend
# For production, use your Vercel-deployed backend URL
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND API CONNECTION (Required)
# ----------------------------------------------------------------------------
# Development: http://localhost:3000 (default Next.js port)
# Production: https://psychage-backend.vercel.app (your deployed backend)
VITE_API_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# ----------------------------------------------------------------------------
# Get from: supabase.com/dashboard → Project Settings → API
# Must match the backend's Supabase configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------------
# SANITY CMS CONFIGURATION (Required for content)
# ----------------------------------------------------------------------------
# Get from: sanity.io/manage → Project Settings
# Must match the backend's Sanity configuration
VITE_SANITY_PROJECT_ID=your-sanity-project-id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# ----------------------------------------------------------------------------
# SERVER-SIDE KEYS (Required for AI / admin features)
# ----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
# Used by: MindMate AI chat (/api/ai/chat)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Get from: https://platform.openai.com/api-keys
# Used by: Content embeddings for RAG search
OPENAI_API_KEY=sk-your-key

# Get from: Supabase dashboard → Settings → API → service_role (secret)
# Used by: Server-side API routes. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Switch primary LLM: 'anthropic' (default) or 'openai'
LLM_PROVIDER=anthropic

# ----------------------------------------------------------------------------
# DOMAIN SEPARATION (Optional — for multi-domain deployment)
# ----------------------------------------------------------------------------
# When deploying main site and admin panel on separate domains,
# set these to enable cross-domain redirects and routing.
# For local dev, leave unset (defaults to current origin).
# VITE_MAIN_URL=https://psychage.com
# VITE_ADMIN_URL=https://admin.psychage.com

# ----------------------------------------------------------------------------
# APPLICATION METADATA (Optional)
# ----------------------------------------------------------------------------
VITE_APP_NAME=Psychage
VITE_APP_VERSION=2.0.0

# ----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# ----------------------------------------------------------------------------
# Set to 'true' or 'false' to enable/disable features
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_PROVIDER_DIRECTORY=true
VITE_ENABLE_MOOD_JOURNAL=true
VITE_ENABLE_SLEEP_TRACKER=true
VITE_ENABLE_CLARITY_SCORE=true
VITE_ENABLE_MEDICATION_TRACKER=true

# Crisis System Features
VITE_CRISIS_DETECTION_ENABLED=true
VITE_MOOD_TRACKING_ENABLED=true
VITE_SAFETY_PLAN_ENABLED=true

# Navigator Condition Expansion — Phased Rollout
# Tier 1 (SCZ, BPD, BN, PGD): Set to 'true' when ready
# Tier 2 (ASD, BDD, DPDR, SPP, PMDD): Enable after Tier 1 stabilizes
# Tier 3 (SADD, HD, SSD, IAD, AVPD, SEPA): Enable after Tier 2 stabilizes
VITE_NAV_TIER1_ENABLED=false
VITE_NAV_TIER2_ENABLED=false
VITE_NAV_TIER3_ENABLED=false

# Phase 4 Expansion — Additional Tiers
# Tier 4 (NPD, ASPD, CPTSD, DID): High clinical severity conditions
# Tier 5 (DPD, SZPD, OSDD, ASD_ACUTE, TTM, SPD_EXCOR): Moderate-high complexity
# Tier 6 (IED, HYPER, ARFID, CYC): Extensions to existing categories
VITE_NAV_TIER4_ENABLED=false
VITE_NAV_TIER5_ENABLED=false
VITE_NAV_TIER6_ENABLED=false

# Navigator Age Gate (requires legal review before enabling)
VITE_NAVIGATOR_AGE_GATE=false
VITE_NAVIGATOR_AGE_GATE_MIN_AGE=13

# ----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS (Optional)
# ----------------------------------------------------------------------------
# Set to 'true' for verbose logging in console
# IMPORTANT: Set to 'false' for production deployment
VITE_DEBUG_MODE=false
